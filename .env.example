# ============================================================
# Vessa — Environment Variables (example)
# ============================================================
# Copy this file to `.env.local` and fill in the values you need.
#   cp .env.example .env.local
#
# The app runs at ZERO cost out of the box:
#   - No keys set        -> Demo mode (realistic simulated AI, free forever)
#   - One free AI key    -> Real AI on a free tier (Gemini or Groq)
#   - Both free AI keys  -> Best-of-two: runs both models per request and
#                           keeps the stronger answer automatically
#   - No Razorpay keys   -> Checkout runs in demo mode (no charge)
#
# NEVER commit your real .env.local — it is gitignored on purpose.
# ------------------------------------------------------------

# ---------- AI provider (pick ONE for real AI, or none for demo) ----------

# OPTION 1 — Google Gemini (FREE, no credit card)
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OPTION 2 — Groq (FREE, very fast Llama models)
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OPTION 3 — Anthropic Claude (PAID, optional)
# https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------- Billing: Razorpay (works in India) ----------
# Get test keys: https://dashboard.razorpay.com/app/keys
# Leave blank to run checkout in demo mode (no real charge).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---------- Optional: Supabase (auth / database) ----------
# https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
